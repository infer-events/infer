{
  "name": "@inferevents/sdk",
  "version": "0.1.12",
  "description": "Event collection SDK for Infer — analytics designed for AI agents, not dashboards",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infer-events/infer.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/infer-events/infer/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/infer-events/infer/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "sideEffects": false,
  "license": "MIT"
}
